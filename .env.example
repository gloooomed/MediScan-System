# Frontend API base URL for production deployments.
# Leave empty for local dev with Vite proxy (/api -> localhost:3000).
VITE_API_BASE_URL=

# Backend only (for app.js hosting platforms like Render/Railway/Cloud Run).
# Comma-separated list of allowed frontend origins.
# Example:
# CORS_ORIGIN=https://your-frontend.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=
